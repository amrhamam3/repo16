<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://android.com">
    <!-- الخلفية الفحمية المطفية المستوحاة من شعارك الشخصي -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#1A1A1E" />
        </shape>
    </item>

    <!-- التوهج الكهرماني الدافئ المنبثق خلف اللوجو والشريط -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="radial"
                android:gradientRadius="450dp"
                android:startColor="#26FF9500"
                android:centerColor="#0DFF9500"
                android:endColor="#00000000" />
        </shape>
    </item>
</layer-list>
