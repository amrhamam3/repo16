<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/splash_grid_bg"
    android:clipChildren="false"
    android:clipToPadding="false">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="16dp">

        <ImageView
            android:id="@+id/splashLogo"
            android:layout_width="160dp"
            android:layout_height="160dp"
            android:layout_marginBottom="24dp"
            android:contentDescription="Amr Hamam 3D Logo"
            android:scaleType="fitCenter"
            android:src="@mipmap/ic_launcher" />

        <TextView
            android:id="@+id/splashTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Amr 3D Preview Pro"
            android:textColor="#FFF8E7"
            android:textSize="26sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"
            android:shadowColor="#4DFF9800"
            android:shadowDx="0"
            android:shadowDy="4"
            android:shadowRadius="10" />

        <TextView
            android:id="@+id/splashDev"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="3D Designer Edition"
            android:textColor="#B3E6D7B8"
            android:textSize="14sp"
            android:letterSpacing="0.1" />

    </LinearLayout>

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_marginBottom="48dp"
        android:paddingHorizontal="36dp"
        android:clipChildren="false"
        android:clipToPadding="false">

        <TextView
            android:id="@+id/splashProgressText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0%"
            android:textColor="#FFF8E7"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"
            android:shadowColor="#99FF9800"
            android:shadowRadius="6" />

        <ProgressBar
            android:id="@+id/splashProgress"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="12dp"
            android:layout_below="@id/splashProgressText"
            android:max="100"
            android:progress="0" />

    </RelativeLayout>

    <View
        android:id="@+id/splashGlowLine"
        android:layout_width="match_parent"
        android:layout_height="3dp"
        android:layout_centerInParent="true"
        android:background="#FFAC33" />

</RelativeLayout>